# Скопируй в .env и заполни. .env НЕ коммить (см. .gitignore).

# Токен бота от @BotFather
TELEGRAM_TOKEN=

# API-ключ Anthropic (console.anthropic.com) — структурирование и сводка
ANTHROPIC_API_KEY=

# API-ключ OpenAI — расшифровка голосовых через Whisper
OPENAI_API_KEY=

# Модель Claude
CLAUDE_MODEL=claude-sonnet-5

# ВАЖНО (безопасность): твой Telegram user id. Узнать через /start у бота.
# Если пусто — бот НИКОГО не пустит (fail-closed). Можно несколько через запятую.
ALLOWED_USER_ID=

# Где хранить заметки по дням (по умолчанию ./notes)
NOTES_DIR=notes
